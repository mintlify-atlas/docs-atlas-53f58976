  "keyFeatures": [
    "Full open-source reimplementation of the MechCommander 2 engine",
    "OpenGL rendering with GLSL shader support",
    "Cross-platform: Linux and Windows (64-bit)",
    "SDL2-based audio, input, and window management",
    "gosFX particle effects system",
    "ABL scripting language interpreter for mission logic",
    "FastFile (.fst) archive format for game assets",
    "Terrain rendering with texture management",
    "Save/load game functionality",
    "Data conversion and asset pipeline tools"
  ],
  "publicApiSurface": [
    "GameOS abstraction layer (gameos.hpp)",
    "gosFX particle effects system (gosfx.hpp)",
    "Terrain class (terrain.h)",
    "SoundSystem (soundsys.h)",
    "MechLib (mclib.h)",
    "Mission scripting via ABL interpreter",
    "Data tools: aseconv, makefst, makersp, pak, text_tool",
    "system.cfg configuration file",
    "FastFile (.fst) asset archives"
